# Copy to .env and fill in. Never commit .env.
# Google Gemini API key — required from Phase 3 (actual model calls).
# Phase 1 (rule-based routing) does not call any model and needs no key.
GOOGLE_API_KEY=

# Optional: override config file locations (defaults shown).
# LLMROUTER_MODELS_CONFIG=config/models.yaml
# LLMROUTER_POLICY_CONFIG=config/policy.yaml

# Optional: tracely routing spans (Phase 5). Spans are emitted ONLY if an
# endpoint is set; leave unset to disable tracing entirely.
# TRACELY_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Point at your meridian/tracely checkout to use its SDK (else raw OTLP is used).
# TRACELY_SDK_PATH=C:\path\to\meridian\meridian-sdk

# Optional: compose-with-semcache demo (Phase 5).
# SEMCACHE_PATH=C:\path\to\semantic_cache
# LLMROUTER_THROTTLE=6      # seconds between real model calls (free-tier RPM)
